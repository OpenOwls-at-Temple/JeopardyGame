# LiteLLM model string — change this to switch providers, zero code changes
LLM_MODEL=deepseek/deepseek-chat

# API key for the chosen provider (LiteLLM reads by name automatically)
DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Hard daily token quota (input + output combined). App returns 429 when hit.
LLM_DAILY_TOKEN_CAP=100000

# Supabase — optional. Quota tracking is skipped if these are not set.
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# Frontend origin for CORS (needed in production — not required for local dev)
# FRONTEND_URL=https://your-app.onrender.com
